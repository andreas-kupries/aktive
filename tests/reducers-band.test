# -*- tcl -*- tcl.tk//DSL tcltest//EN//2.0 tcl.tk//DSL tcltest//EN//2.0
## (c) 2026 Andreas Kupries
# # ## ### ##### ######## ############# #####################
## AKTIVE. Band reducers. Cross check the variants against each other

kt check Tcl     8.6 9
kt check tcltest 2

# # ## ### ##### ######## ############# #####################

kt local testing aktive

kt source support/util.tcl
kt source ../data/reduce/spec.tcl	;# reducer list

# # ## ### ##### ######## ############# #####################
## Syntax - Not relevant for test-only commands

# # ## ### ##### ######## ############# #####################
::aktive::test::reduce-bands::init
set N [::aktive::test::reduce-bands::size]

# # ## ### ##### ######## ############# #####################

foreach d {
    1 2 3 4 5 6 7 8
} {
    set maxw [expr {$N/$d}]
    for {set w 1} {($w < 10000) && ($w < $maxw)} {set w [expr {10*$w}]} {
	# w in {1, 10, 100, 1000}
	foreach name $reducers {
	    # Each test samples the input space (beyond the sampling done over depths and vector lengths)

	    test aktive-reducer-band-special-${name}-$w.$d "aktive reducer $name (special), w$w d$d" -body {
		for {set k 0} {$k < 100} {incr k} {
		    ::aktive::test::reduce-bands::init [expr {$w * $d}]
		    set expected [::aktive::test::reduce-bands::base::$name    $w $d]
		    set actual   [::aktive::test::reduce-bands::special::$name $w $d]
		    set ok       [expr {$expected == $actual}]
		    if {!$ok} break
		}
		set ok
	    } -result 1

	    test aktive-reducer-band-unroll4-${name}-$w.$d "aktive reducer $name (unroll4), w$w d$d" -body {
		for {set k 0} {$k < 100} {incr k} {
		    ::aktive::test::reduce-bands::init [expr {$w * $d}]
		    set expected [::aktive::test::reduce-bands::base::$name    $w $d]
		    set actual   [::aktive::test::reduce-bands::unroll4::$name $w $d]
		    set ok       [expr {$expected == $actual}]
		    if {!$ok} break
		}
		set ok
	    } -result 1
	}
    }
}

# # ## ### ##### ######## ############# #####################
cleanupTests
return
